# Copy this file to .env.local and fill in your own values.

# Plaid (get these from https://dashboard.plaid.com)
PLAID_CLIENT_ID=
PLAID_SECRET=
# sandbox | production
PLAID_ENV=sandbox
# OAuth redirect URL — required for OAuth banks (Chase, Amex, ...). Must be https
# and registered in the Plaid dashboard under this exact string. Leave blank on
# plain localhost; set it to your tunnel/deploy URL to link real OAuth banks.
PLAID_REDIRECT_URI=

# Where the SQLite file lives (optional; defaults to mulch.db)
DATABASE_PATH=mulch.db

# 32-byte hex key used to encrypt stored Plaid access tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

